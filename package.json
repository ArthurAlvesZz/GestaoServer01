{
  "name": "ai-studio-applet",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "eslint .",
    "clean": "next clean",
    "typecheck": "tsc --noEmit",
    "prisma:generate": "prisma generate",
    "prisma:migrate": "prisma migrate deploy",
    "prisma:seed": "prisma db seed",
    "db:setup": "npm run prisma:generate && npm run prisma:migrate && npm run prisma:seed",
    "backup": "sh ./scripts/backup.sh",
    "restore": "sh ./scripts/restore.sh",
    "server:setup": "npx tsx scripts/setup.ts",
    "server:install": "echo 'Run install scripts manually from /scripts/ (Windows/Linux)'",
    "server:start": "npm run start",
    "server:stop": "echo 'Run stop service script from /scripts/'",
    "server:restart": "echo 'Run restart service script from /scripts/'",
    "server:status": "curl http://localhost:3000/api/system/status",
    "server:logs": "cat logs/app.log",
    "server:backup": "npm run backup",
    "server:uninstall": "echo 'Run uninstall scripts manually from /scripts/'"
  },
  "dependencies": {
    "@google/genai": "^2.4.0",
    "@hookform/resolvers": "^5.2.1",
    "@prisma/client": "^5.22.0",
    "autoprefixer": "^10.4.21",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "date-fns": "^4.4.0",
    "lucide-react": "^0.553.0",
    "motion": "^12.23.24",
    "next": "^15.4.9",
    "postcss": "^8.5.6",
    "react": "^19.2.1",
    "react-dom": "^19.2.1",
    "tailwind-merge": "^3.3.1"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "4.1.11",
    "@tailwindcss/typography": "^0.5.19",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "eslint": "9.39.1",
    "eslint-config-next": "16.0.8",
    "firebase-tools": "^15.0.0",
    "prisma": "^5.22.0",
    "tailwindcss": "4.1.11",
    "tw-animate-css": "^1.4.0",
    "typescript": "5.9.3"
  }
}
